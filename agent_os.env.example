# Copy to agent_os.env in the repo root (agent_os.env is gitignored).
# The supervisor loads agent_os.env on startup, then .env.local (workbench-style, including
# `export KEY=value`). Existing shell env vars win over both files.
#
# Cursor Dashboard → Cloud Agents → create API key
# https://cursor.com/dashboard/cloud-agents

CURSOR_API_KEY=
CURSOR_ISSUE_CHAT_REPOSITORY=https://github.com/your-org/your-repo
CURSOR_ISSUE_CHAT_REF=main

# Optional explicit model (default is "default" in Cursor)
# CURSOR_ISSUE_CHAT_MODEL=default

# Keep Cloud Agent records after each chat (default: delete after read)
# CURSOR_ISSUE_CHAT_KEEP_AGENT=0

# Fast issue chat (seconds): OpenAI Chat Completions — no GitHub agent.
# OPENAI_API_KEY=sk-...
# ISSUE_CHAT_MODEL=gpt-4o-mini
#
# If both CURSOR_API_KEY and OPENAI_API_KEY are set, Cursor wins unless you force OpenAI:
# ISSUE_CHAT_PREFER_OPENAI=1
