{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "status-file.schema.json",
  "title": "Agent Status File",
  "description": "Schema for all *-status.json agent dashboard files. Validated by scripts/validate_status_files.py.",
  "type": "object",
  "required": ["schema_version", "updated", "priorities", "actions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["v1.0"],
      "description": "Must be exactly 'v1.0'. (C-8)"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date of last update."
    },
    "priorities": {
      "type": "array",
      "maxItems": 5,
      "description": "Active priorities — max 5. (C-7)",
      "items": {
        "$ref": "#/definitions/priority"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "opportunities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/priority"
      }
    }
  },
  "definitions": {
    "priority": {
      "type": "object",
      "required": ["id", "title", "status", "risk", "note"],
      "description": "Priority object required fields. (C-4)",
      "properties": {
        "id": {
          "type": ["string", "integer"],
          "description": "Unique identifier within this file."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["queued", "in-progress", "needs-review", "paused", "done"],
          "description": "Allowed status values. (C-4)"
        },
        "risk": {
          "type": "string",
          "enum": ["low", "med", "high"],
          "description": "Allowed risk values. (C-4)"
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "proposed_solution": {
          "type": "string"
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string"
        },
        "last_run": {
          "type": ["string", "null"]
        },
        "output_location": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
