export PIXELLAB_API_KEY="paste_key_here"

# Agent OS supervisor (issue chat, API usage pull) — same file as workbench keys
# export OPENAI_API_KEY="sk-..."
# export OPENAI_ADMIN_API_KEY="sk-admin-..."   # org usage/costs for dashboard pull
# export ISSUE_CHAT_MODEL=gpt-4o-mini
# export ISSUE_CHAT_PREFER_OPENAI=1
# export CURSOR_API_KEY="key_..."             # Cursor Cloud Agents API key (Dashboard → Cloud Agents)
# export CURSOR_CLOUD_REPOSITORY="https://github.com/your-org/your-repo"   # GitHub repo the agent can work in
# export CURSOR_CLOUD_REPOSITORY_REF="main"   # optional branch/ref (default main)
# export CURSOR_CLOUD_AGENT_MODEL="composer-2"  # optional; explicit model for POST /v0/agents (see Cursor docs)
# export CURSOR_CLOUD_AGENT_POLL_TIMEOUT_SEC=1800  # optional: max seconds to wait for FINISHED
# export CURSOR_CLOUD_AGENT_POLL_INTERVAL_SEC=5   # optional: poll interval seconds
# export MV_ROOM_ENV_IMAGE_PROVIDER=gemini       # optional server default: gemini | cursor_cloud

# Email delivery — Resend API (shared by weekly digest + daily product reports)
# export RESEND_API_KEY="re_..."
# export DIGEST_EMAIL_TO="tim.a.wood@outlook.com"
# Optional: override the From address (default: onboarding@resend.dev)
# export DIGEST_EMAIL_FROM="MV Agent OS <onboarding@resend.dev>"
#
# Weekly digest cron:  7 9 * * 1     scripts/weekly_digest.sh
# Daily report cron:   7 18 * * *    scripts/daily_product_report.sh
# Room environment v3: omit backwall_panel slots from the assembly plan (experiment; background/midground only)
# export MV_V3_BACKWALL_PANEL=0
#
# Unified chamber shell: one Gemini foreground_frame-sized slot for the full chamber bbox; walkable polygon punched transparent after generation (skips legacy ceiling/wall/main_floor strips when biome has foreground_frame)
# export MV_ROOM_SHELL_FOREGROUND=1
# Optional: shrink transparent walkable hole inward by N px (0–48) so a thicker stone rim survives punchout; default 0 (true walkable match).
# export MV_ROOM_SHELL_PUNCH_INSET_PX=4
#
# Room layout editor — Environment Copilot (Gemini). Loaded when starting sprite_workbench_server.py
# export GEMINI_API_KEY="paste_key_here"
# Or use the name from Google AI Studio (same value works for image generation):
# export GOOGLE_API_KEY="paste_key_here"
# If the API returns HTTP 429 "exceeded its spending cap", raise the budget/spending cap on the
# Google Cloud project tied to that key (AI Studio → your key → Google Cloud project → Billing).
# Optional model override (default: gemini-2.5-flash)
# export GEMINI_MODEL=gemini-2.5-flash
# Optional: sprite workbench server log verbosity (DEBUG shows more Pixel Lab diagnostics)
# export SPRITE_WORKBENCH_LOG_LEVEL=INFO
# Optional: urllib read timeout (seconds) for each Pixel Lab HTTP request (POST accept can be slow)
# export SPRITE_WORKBENCH_PIXELLAB_HTTP_TIMEOUT=180
# After parallel polls settle, retry only failed directions with one POST each (default on)
# export PIXELLAB_ANIMATE_SERIAL_FALLBACK=1
# Max seconds to poll Pixel Lab for custom animations (animate-with-text-v2); default 900
# export PIXELLAB_ANIMATE_CUSTOM_POLL_TIMEOUT_SECONDS=900
